{
  "version": 2,
  "builds": [
    {
      "src": "config/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "config/wsgi.py"
    },
    {
      "src": "/media/(.*)",
      "dest": "config/wsgi.py"
    },
    {
      "src": "/(.*)",
      "dest": "config/wsgi.py"
    }
  ]
}